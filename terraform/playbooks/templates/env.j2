# Allowing python to print() in docker
PYTHONUNBUFFERED=1

COMPOSE_PROJECT_NAME=superset
SECRET_KEY = "{{ secret_key }}"
DEV_MODE=false

# Port configuration (override in .env-local for multiple instances)
# NGINX_PORT=80
# SUPERSET_PORT=8088
# NODE_PORT=9000
# WEBSOCKET_PORT=8080
# CYPRESS_PORT=8081
# DATABASE_PORT=5432
# REDIS_PORT=6379

# database configurations
SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://{{ db_user }}:{{ db_password }}@{{ db_endpoint }}/superset

# Add the mapped in /app/pythonpath_docker which allows devs to override stuff
#PYTHONPATH=/app/pythonpath:/app/config
#SUPERSET_CONFIG_PATH=/app/config/superset_config.py
REDIS_HOST={{ cache_endpoint }}
REDIS_PORT=6379
REDIS_CELERY_DB = 0
REDIS_RESULTS_DB = 1
RATELIMIT_STORAGE_URI = "redis://{{ cache_endpoint }}:6379/2"

# Superset specific config
ROW_LIMIT = 5000

# Development and logging configuration
# FLASK_DEBUG: Enables Flask dev features (auto-reload, better error pages) - keep 'true' for development
FLASK_DEBUG=false
# SUPERSET_LOG_LEVEL: Controls Superset application logging verbosity (debug, info, warning, error, critical)
SUPERSET_LOG_LEVEL=info

SUPERSET_APP_ROOT="/"
SUPERSET_ENV=production
SUPERSET_LOAD_EXAMPLES=no
CYPRESS_CONFIG=false
SUPERSET_PORT=8088
MAPBOX_API_KEY=''


TALISMAN_ENABLED = false
WTF_CSRF_ENABLED = false

SQLLAB_CTAS_NO_LIMIT = true

# Make sure you set this to a unique secure random value on production
ENABLE_PLAYWRIGHT=false
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
BUILD_SUPERSET_FRONTEND_IN_DOCKER=true
