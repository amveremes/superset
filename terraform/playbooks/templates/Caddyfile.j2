# Caddyfile — Reverse proxy HTTPS automatique for Superset (template)
# Use `domain_name` variable from the playbook

# Local only : self-signed certificates
localhost {
    reverse_proxy superset-app:8088 {
        header_down -Server
        header_up X-Forwarded-For {http.request.remote.host}
        header_up X-Forwarded-Proto {http.request.proto}
        header_up X-Forwarded-Host {http.request.host}
    }
    encode gzip
    log {
        output stdout
        format json
    }
}

# For real domain (provided by `domain_name` variable) :
{{ domain_name }} {
    reverse_proxy superset-app:8088
    encode gzip
    log {
        output stdout
        format json
    }
}
